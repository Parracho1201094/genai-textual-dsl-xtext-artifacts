<?xml version="1.0" encoding="UTF-8"?>
<project default="generate" name="excelltsmetamodel.acceleo">
    <property name="ECLIPSE_HOME" value="../../../../../../../../eclipse/modeling-2024-03/Eclipse.app/Contents/Eclipse"/>
    <property name="ECLIPSE_WORKSPACE" value="../../../../../../../../eclipse/runtime-New_configuration"/>

    <!-- The classpath with only the dependencies used by the project -->
    <path id="excelltsmetamodel.acceleo.libraryclasspath">
        <pathelement location="${ECLIPSE_WORKSPACE}/excelltsmetamodel.acceleo/bin"/>
    </path>

    <path id="excelltsmetamodel.acceleo.classpath">
        <path refid="excelltsmetamodel.acceleo.libraryclasspath"/>
    </path>

    <!-- The classpath with only the jars available in the plugin folder of Eclipse -->
    <path id="excelltsmetamodel.acceleo.libraryclasspath.alljars">
        <pathelement location="../excelltsmetamodel.acceleo/bin"/>
        <fileset dir="${ECLIPSE_HOME}/plugins/" includes="*.jar"/>
    </path>

    <path id="excelltsmetamodel.acceleo.classpath.alljars">
        <path refid="excelltsmetamodel.acceleo.libraryclasspath.alljars"/>
    </path>

    <!-- The default task with the jars used by this project -->
    <target name="generate">
        <java classname="excelltsmetamodel.acceleo.main.Generate" classpathref="excelltsmetamodel.acceleo.classpath">
            <arg value="${model}"/>
            <arg value="${target}"/>
        </java>
    </target>

    <!--
        In case of problem you can also try with all the jar available in your Eclipse
        Keep in mind that having two versions of the same jar can create problems
    -->
    <target name="generate.alljars">
        <java classname="excelltsmetamodel.acceleo.main.Generate" classpathref="excelltsmetamodel.acceleo.classpath">
            <arg value="${model}"/>
            <arg value="${target}"/>
        </java>
    </target>
</project>
