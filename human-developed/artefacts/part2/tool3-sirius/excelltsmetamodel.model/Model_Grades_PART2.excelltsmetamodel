  <steps xsi:type="excelltsmetamodel:RemoveDuplicates" name="Remove id_grades duplicated" description="Remove all id_grades that could be duplicated" next="//@steps.2" table="//@tables.2" column="//@tables.2/@columns.0"/>
  <steps xsi:type="excelltsmetamodel:Group" name="Group By id_student and AVG grande" description="It will group by student and calculate the AVG for the grades" next="//@steps.3" table="//@tables.2" groupBy="//@tables.2/@columns.2 //@tables.2/@columns.1" resultTable="//@tables.3" operandColumn="//@tables.2/@columns.3" operation="AVERAGE" resultColumn="//@tables.3/@columns.2"/>
