    <selectColumns href="Model_Grades.excelltsmetamodel#//@tables.0/@columns.1"/>
    <selectColumns href="#//@tables.4/@columns.1"/>
    <selectColumns href="#//@tables.2/@columns.3"/>
    <selectColumns href="#//@tables.5/@columns.3"/>
