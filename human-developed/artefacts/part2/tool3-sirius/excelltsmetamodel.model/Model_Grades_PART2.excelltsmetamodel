    <associations originCol="//@tables.4/@columns.1" destinCol="//@tables.5/@columns.1"/>
    <associations originCol="//@tables.4/@columns.2" destinCol="//@tables.5/@columns.2"/>
    <associations originCol="//@tables.4/@columns.3" destinCol="//@tables.5/@columns.3"/>
  </steps>
  <steps xsi:type="excelltsmetamodel:Join" description="Joins with the objective to get the student name" next="//@steps.6" tableLeft="//@tables.5" tableRight="//@tables.0" columnLeft="//@tables.5/@columns.0" columnRight="//@tables.0/@columns.0" resultTable="//@tables.6">
