              <firstModelOperations xsi:type="tool:CreateInstance" typeName="excelltsmetamodel::Table" referenceName="tables">
                <subModelOperations xsi:type="tool:SetValue" featureName="name" valueExpression="aql: 'Table ' + container.tables->size()"/>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool_1:NodeCreationDescription" name="NC_ColumnDescription" label="Create Column" forceRefresh="true" nodeMappings="//@ownedViewpoints[name='LTS%20Viewpoint']/@ownedRepresentations[name='LTS_Model_Diagram']/@defaultLayer/@containerMappings[name='C_Table']/@subNodeMappings[name='SN_Column_Description']" iconPath="/excelltsmetamodel.design/description/icons/column.png">
