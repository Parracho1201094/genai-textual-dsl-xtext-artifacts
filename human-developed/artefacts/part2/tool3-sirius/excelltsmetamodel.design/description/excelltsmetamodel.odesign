        <toolSections name="Generation Section">
          <ownedTools xsi:type="tool:PopupMenu" name="Menu Model Operation">
            <menuItemDescription xsi:type="tool:OperationAction" name="Generate Graphical Projection">
              <view name="views"/>
              <initialOperation>
                <firstModelOperations xsi:type="tool:ChangeContext" browseExpression="aql:self">
                  <subModelOperations xsi:type="tool:Let" valueExpression="service:generateGraphicalProjection()"/>
                </firstModelOperations>
              </initialOperation>
            </menuItemDescription>
            <menuItemDescription xsi:type="tool:OperationAction" name="Generate Textual Projection">
              <view name="views"/>
              <initialOperation>
                <firstModelOperations xsi:type="tool:ChangeContext" browseExpression="aql:self">
                  <subModelOperations xsi:type="tool:Let" valueExpression="service:textualProjection()"/>
                </firstModelOperations>
              </initialOperation>
            </menuItemDescription>
          </ownedTools>
        </toolSections>
        <toolSections name="Concrete Sintax Creation">
          <ownedTools xsi:type="tool_1:EdgeCreationDescription" name="ED_Next_Step" label="Edge - Step To Next Step" forceRefresh="true" edgeMappings="//@ownedViewpoints[name='LTS%20Viewpoint']/@ownedRepresentations[name='LTS_Model_Diagram']/@defaultLayer/@edgeMappings[name='R_Step_To_Step']">
            <sourceVariable name="source"/>
            <targetVariable name="target"/>
            <sourceViewVariable name="sourceView"/>
            <targetViewVariable name="targetView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool:ChangeContext" browseExpression="var:source">
                <subModelOperations xsi:type="tool:SetValue" featureName="next" valueExpression="var:target"/>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool_1:ContainerCreationDescription" name="CC_Table" label="Create Table" forceRefresh="true" containerMappings="//@ownedViewpoints[name='LTS%20Viewpoint']/@ownedRepresentations[name='LTS_Model_Diagram']/@defaultLayer/@containerMappings[name='C_Table']" iconPath="/excelltsmetamodel.design/description/icons/table.png">
