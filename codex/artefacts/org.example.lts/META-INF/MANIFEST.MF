 org.example.lts.scoping,
 org.example.lts.serializer,
 org.example.lts.services,
 org.example.lts.validation
Require-Bundle: org.antlr.runtime;bundle-version="[3.2.0,3.2.1)",
 org.eclipse.emf.common,
 org.eclipse.emf.ecore,
 org.eclipse.xtend.lib;bundle-version="2.40.0",
 org.eclipse.xtext,
 org.eclipse.xtext.xbase.lib;bundle-version="2.40.0"
Import-Package: org.apache.log4j
Automatic-Module-Name: org.example.lts
