module org.example.lts.GenerateLts

import org.eclipse.xtext.xtext.generator.*
import org.eclipse.xtext.xtext.generator.model.project.*

var rootPath = ".."

Workflow {
    component = XtextGenerator {
        configuration = {
            project = StandardProjectConfig {
                baseName = "org.example.lts"
                rootPath = rootPath
                runtimeTest = {
                    enabled = true
                }
                genericIde = {
                    enabled = true
                }
                eclipsePlugin = {
                    enabled = true
                }
                eclipsePluginTest = {
                    enabled = true
                }
                createEclipseMetaData = true
            }
            code = {
                encoding = "UTF-8"
                lineDelimiter = "\n"
                fileHeader = "/* Generated by Xtext. */"
                preferXtendStubs = false
            }
        }
        language = StandardLanguage {
            name = "org.example.lts.Lts"
            fileExtensions = "lts"
            serializer = {
                generateStub = false
            }
            validator = {
            }
        }
    }
}
